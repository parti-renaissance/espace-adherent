{% extends 'security/renaissance_layout.html.twig' %}

{% block title 'Réinitialiser mon mot de passe' %}

{% form_theme form 'renaissance/forms/tailwind_form_theme.html.twig' %}

{% block security_block_title %}
    <span>Je réinitialise</span>
    <span class="bg-vox-yellow-200 px-2 py-1 whitespace-nowrap">mon mot de passe</span>
{% endblock %}

{% block security_content %}
    {% set sentEmail = app.flashes('reset_password_sent')|first %}

    {% if sentEmail %}
        <div class="bg-vox-gray-100 rounded-2xl px-5 py-4 text-[16px] leading-[22px] text-vox-gray-900">
            Si un compte <span class="font-semibold">{{ sentEmail }}</span> existe, vous recevrez un email dans quelques instants.<br/><br/>
            <span class="flex items-start gap-1.5">
                <i data-lucide="info" class="shrink-0 mt-[3px] w-4 h-4"></i>Cliquez sur le bouton qu'il contient pour changer votre mot de passe.
            </span>
        </div>
    {% endif %}

    {{ form_start(form, {
        attr: {
            class: 'flex flex-col gap-4 w-full',
            'x-data': '{ isSubmitting: false }',
            '@submit': 'isSubmitting = true',
        },
    }) }}
        {% if error is defined %}
            <twig:ReParagraphStatus status="error" icon>
                {{- error.messageKey|trans(error.messageData)|raw -}}
            </twig:ReParagraphStatus>
        {% endif %}

        {{ form_errors(form) }}

        {% if sentEmail %}
            <p class="font-normal text-[16px] leading-[22px] tracking-normal text-vox-gray-600 pt-8 pb-1">Si vous n'avez rien reçu, vérifiez votre saisie avant de réessayer.</p>
        {% endif %}

        {{ form_row(form.email, {
            attr: {
                placeholder: 'Adresse email',
                validate: "['required']",
                autocomplete: 'email',
            }, label: false}) }}

        <twig:ReButton
            color="blue"
            class="w-full rounded-full py-3.5 text-[16px] font-semibold bg-vox-blue-600 text-white hover:enabled:bg-vox-blue-700 transition-opacity duration-200"
            disabled="x:isSubmitting"
        >
            <span x-show="!isSubmitting">
                Réinitialiser
            </span>
            <span x-show="isSubmitting" x-cloak class="flex items-center justify-center gap-2">
                <svg class="animate-spin h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
                Envoi en cours...
            </span>
        </twig:ReButton>
    {{ form_end(form) }}

    <a href="{{ path('app_renaissance_login') }}" class="mt-8 self-center text-vox-blue-600 hover:underline text-[14px] font-semibold">← Page précédente</a>
{% endblock %}
