{% import 'admin/macros/labels.html.twig' as ui %}

{% set displayed_tags = [] %}

<div style="display: flex; flex-direction: column; align-items: flex-start; gap: 1px;">
    {# 1. Tags "adherent:*" ou "sympathisant:*" #}
    {% for tag in object.tags %}
        {% if tag starts with 'adherent:' %}
            {{ ui.label(
                translate_tag(tag, false),
                object.hasActiveMembership() ? '#ffeccc' : '#d6e7ff',
                object.hasActiveMembership() ? '#8e681e' : '#0f72bd',
            ) }}
            {% set displayed_tags = displayed_tags|merge([tag]) %}
        {% elseif tag starts with 'sympathisant:' %}
            {{ ui.label(
                translate_tag(tag, false),
                '#e3f8ff',
                '#4890a8',
            ) }}
            {% set displayed_tags = displayed_tags|merge([tag]) %}
        {% endif %}
    {% endfor %}

    {# 2. Tags "elu:*" #}
    {% set bgColor = '#fcede7' %}
    {% set textColor = '#fd6a3d' %}

    {% for tag in object.tags %}
        {% if tag starts with 'elu:' %}
            {{ ui.label(translate_tag(tag, false), bgColor, textColor) }}
            {% set displayed_tags = displayed_tags|merge([tag]) %}
        {% endif %}
    {% endfor %}

    {# 3. Zone-based roles #}
    {% set bgColor = '#ece2ff' %}
    {% set textColor = '#714991' %}

    {% for zone_based_role in object.getZoneBasedRoles() %}
        {% set role_type = zone_based_role.getType() %}
        {% set label %}
            {% set role_label = ('role.' ~ role_type)|trans({gender: object.gender}) %}
            {% set instance = '' %}

            {% if role_type starts with ('national_') %}
                {% set instance = constant('App\\Scope\\ScopeEnum::SCOPE_INSTANCES')[role_type] ?? '' %}
            {% endif %}

            {{ instance ? instance ~ ' :' }} {{ role_label }}

            {% if zone_based_role.zones is not empty %}
                {% set labels = [] %}
                {% for zone in zone_based_role.zones %}
                    {% set labels = labels|merge([zone.type == 'region' ? zone.name : zone.code]) %}
                {% endfor %}
                ({{ labels|join(', ') }})
            {% endif %}
        {% endset %}

        {% set tooltip %}
            {% if zone_based_role.zones is not empty %}
                {% set zones = [] %}
                {% for zone in zone_based_role.zones %}
                    {% set zones = zones|merge([zone.name ~ ' (' ~ zone.code ~ ')']) %}
                {% endfor %}
                {{ zones|join(', ') }}
            {% endif %}
        {% endset %}

        {{ ui.label(label, bgColor, textColor, tooltip, 'left') }}
    {% endfor %}

    {# 3b. Animator role (from Committee relationship, not ZoneBasedRole) #}
    {% if object.isAnimator %}
        {% set committees = object.animatorCommittees %}
        {% set names = [] %}
        {% for committee in committees %}
            {% set names = names|merge([committee.name]) %}
        {% endfor %}
        {% set label = ('role.animator')|trans({gender: object.gender}) ~ (names is not empty ? ' (' ~ names|sort|join(', ') ~ ')' : '') %}
        {% set tooltip %}
            {% for committee in committees %}
                {{ committee.name }}{% if not loop.last %}<br />{% endif %}
            {% endfor %}
        {% endset %}
        {{ ui.label(label, bgColor, textColor, tooltip, 'left') }}
    {% endif %}

    {# 3c. Agora president role (from Agora relationship, not ZoneBasedRole) #}
    {% if object.isPresidentOfAgora %}
        {% set agoras = object.presidentOfAgoras %}
        {% set names = [] %}
        {% for agora in agoras %}
            {% set names = names|merge([agora.name]) %}
        {% endfor %}
        {% set label = ('role.agora_president')|trans({gender: object.gender}) ~ (names is not empty ? ' (' ~ names|sort|join(', ') ~ ')' : '') %}
        {% set tooltip %}
            {% for agora in agoras %}
                {{ agora.name }}{% if not loop.last %}<br />{% endif %}
            {% endfor %}
        {% endset %}
        {{ ui.label(label, bgColor, textColor, tooltip, 'left') }}
    {% endif %}

    {# 3d. Agora general secretary role (from Agora relationship, not ZoneBasedRole) #}
    {% if object.isGeneralSecretaryOfAgora %}
        {% set agoras = object.generalSecretaryOfAgoras %}
        {% set names = [] %}
        {% for agora in agoras %}
            {% set names = names|merge([agora.name]) %}
        {% endfor %}
        {% set label = ('role.agora_general_secretary')|trans({gender: object.gender}) ~ (names is not empty ? ' (' ~ names|sort|join(', ') ~ ')' : '') %}
        {% set tooltip %}
            {% for agora in agoras %}
                {{ agora.name }}{% if not loop.last %}<br />{% endif %}
            {% endfor %}
        {% endset %}
        {{ ui.label(label, bgColor, textColor, tooltip, 'left') }}
    {% endif %}

    {# 4. Délégués #}
    {% for delegated_role in object.getReceivedDelegatedAccesses() %}
        {% set role_type = delegated_role.getType() %}
        {% set delegator = delegated_role.delegator %}

        {% set label = delegated_role.role %}
        {% set tooltip = ('role.' ~ role_type)|trans({gender: object.gender}) ~ ' délégué' ~ (object.gender is same as('female') ? 'e') %}

        {% if role_type is same as(constant('App\\Scope\\ScopeEnum::ANIMATOR')) %}
            {% set committees = [] %}
            {% for committee in delegator.getAnimatorCommittees() %}
                {% set committees = committees|merge([committee.name]) %}
            {% endfor %}

            {% if committees is not empty %}
                {% set label = label ~ ' (' ~ committees|sort|join(', ') ~ ')' %}
            {% endif %}
        {% elseif role_type is same as(constant('App\\Scope\\ScopeEnum::AGORA_PRESIDENT')) %}
            {% set agoras = [] %}
            {% for agora in delegator.presidentOfAgoras %}
                {% set agoras = agoras|merge([agora.name]) %}
            {% endfor %}

            {% if agoras is not empty %}
                {% set label = label ~ ' (' ~ agoras|sort|join(', ') ~ ')' %}
            {% endif %}
        {% elseif role_type is same as(constant('App\\Scope\\ScopeEnum::AGORA_GENERAL_SECRETARY')) %}
            {% set agoras = [] %}
            {% for agora in delegator.generalSecretaryOfAgoras %}
                {% set agoras = agoras|merge([agora.name]) %}
            {% endfor %}

            {% if agoras is not empty %}
                {% set label = label ~ ' (' ~ agoras|sort|join(', ') ~ ')' %}
            {% endif %}
        {% else %}
            {% set zone_based_role = delegator.findZoneBasedRole(role_type) %}

            {% if zone_based_role and zone_based_role.zones is not empty %}
                {% set zones = [] %}
                {% set labels = [] %}
                {% for zone in zone_based_role.zones %}
                    {% set labels = labels|merge([zone.type == 'region' ? zone.name : zone.code]) %}
                    {% set zones = zones|merge([zone.name ~ ' (' ~ zone.code ~ ')']) %}
                {% endfor %}

                {% set label = label ~ ' (' ~ labels|join(', ') ~ ')' %}

                {% set tooltip %}
                    {{ tooltip }}
                    <br />
                    {{ zones|join(', ') }}
                {% endset %}
            {% endif %}
        {% endif %}

        {{ ui.label(label, bgColor, textColor, tooltip, 'left') }}
    {% endfor %}

    {# 5. Rôles / responsabilités divers (hors ZoneBasedRoles déjà affichés en section 3) #}
    {% set customRoleLabels = [
        object.isJecouteManager ? 'jecoute_manager',
        object.isHost ? 'committee_host',
        object.isSupervisor(false) ? 'committee_supervisor',
        object.isHeadedRegionalCandidate ? 'candidate_regional_headed',
        object.isLeaderRegionalCandidate ? 'candidate_regional_leader',
        object.isDepartmentalCandidate ? 'candidate_departmental',
        object.isDelegatedHeadedRegionalCandidate ? 'delegated_candidate_regional_headed',
        object.isDelegatedLeaderRegionalCandidate ? 'delegated_candidate_regional_leader',
        object.isDelegatedDepartmentalCandidate ? 'delegated_candidate_departmental',
        object.hasNationalRole ? 'national',
        object.hasPhoningManagerRole ? 'phoning_national_manager',
        object.hasPapNationalManagerRole ? 'pap_national_manager',
        object.isTerritoireProgresMembership ? 'membership.tdp',
        object.isAgirMembership ? 'membership.agir',
        object.meetingScanner ? 'meeting_scanner',
    ]|filter(v => v) %}

    {% for label in customRoleLabels %}
        {{ ui.label(('role.' ~ label)|trans({gender: object.gender}), bgColor, textColor, null, 'left') }}
    {% endfor %}

    {# 6. Static labels & tags non encore affichés #}
    {% set bgColor = '#dfe3e8' %}
    {% set textColor = '#58636f' %}

    {% for tag in object.tags %}
        {% if tag not in displayed_tags %}
            {{ ui.label(translate_tag(tag, false), bgColor, textColor) }}
            {% set displayed_tags = displayed_tags|merge([tag]) %}
        {% endif %}
    {% endfor %}

    {% for staticLabel in object.staticLabels %}
        {% set tagCode = staticLabel.category.code ~ ':' ~ staticLabel.code %}
        {% if tagCode not in displayed_tags %}
            {{ ui.label(staticLabel.label, bgColor, textColor) }}
            {% set displayed_tags = displayed_tags|merge([tag]) %}
        {% endif %}
    {% endfor %}
</div>
