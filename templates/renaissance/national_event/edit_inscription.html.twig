{% extends 'renaissance/national_event/_inscription_layout.html.twig' %}

{% block background_image '' %}
{% block body_classes 'bg-ui_gray-5' %}

{% block header %}
    <header class="flex py-10 md:py-20 justify-center w-full">
        {% if event.logoImage %}
            <img class="max-h-36" src="{{ vich_uploader_asset(event.logoImage) }}" alt="logo"/>
        {% else %}
            <a href="{{ path('renaissance_site') }}">
                <img src="{{ asset('/images/renaissance/logo-dark.svg') }}" alt="logo" />
            </a>
        {% endif %}
    </header>
{% endblock %}

{% block content_section %}
    <div class="flex flex-col md:flex-row gap-8 justify-center items-center md:items-start w-full px-5 pb-20" x-data="xNationalEventPage({packageConfig: {{ event.packageConfig|json_encode }}})">
        {{ form_start(form, {attr: {class: 'max-w-[500px]'}}) }}
            <div class="flex flex-col gap-8">
                <twig:Atoms:ReCard class="!rounded-2xl !gap-6">
                    {{ include('renaissance/partials/flashes.html.twig', {slim: true}) }}

                    <p class="font-medium text-2xl text-ui_gray-80">Modifier mes informations</p>

                    {{ form_errors(form) }}

                    <div class="flex-col flex gap-4">
                        <twig:Atoms:ReLabel>Mes informations personnelles</twig:Atoms:ReLabel>

                        {{ form_row(form.civility, {
                            label: false,
                            attr: {onCheck: "setFieldValid('gender')", validate: "['required']"},
                        }) }}

                        <div class="flex flex-col xs:flex-row gap-5 ">
                            {{ form_row(form.firstName, {
                                label: false,
                                attr: {placeholder: 'Prénom', onCheck: "setFieldValid('firstName')", validate: "['required', 'min:2', 'max:50']"},
                            }) }}
                            {{ form_row(form.lastName, {
                                label: false,
                                attr: {placeholder: 'Nom', onCheck: "setFieldValid('lastName')", validate: "['required', 'min:1', 'max:50']"},
                            }) }}
                        </div>
                    </div>

                    {{ form_row(form.email, {
                        label: 'Mon adresse email',
                        help: 'Si vous êtes déjà militant, merci de renseigner l\'adresse email de votre compte',
                        attr: {
                            placeholder: 'adresse@mail.com',
                            validate: "['required', 'email']",
                            autocomplete: 'email',
                            onCheck: "setFieldValid('email')",
                        },
                    }) }}

                    {{ form_row(form.postalCode, {
                        label: 'Code postal',
                        attr: {placeholder: '75000', onCheck: "setFieldValid('postalCode')", validate: "['required']"},
                    }) }}

                    <fieldset class="relative">
                        <twig:Atoms:ReLabel class="mb-3">Date de naissance</twig:Atoms:ReLabel>

                        <fieldset class="flex gap-2.5 relative">
                            {{ form_widget(form.birthdate.day, {label: false, attr: {
                                class: 'w-full',
                                placeholder: 'Jour',
                                validate: "['required']",
                                onCheck: "setFieldValid('birthDay')",
                                searchBoxProps: {'x-numberonly': ''},
                            }}) }}

                            {{ form_widget(form.birthdate.month, {label: false, attr: {
                                class: 'w-full',
                                placeholder: 'Mois',
                                validate: "['required']",
                                onCheck: "setFieldValid('birthMonth')",
                            }}) }}

                            {{ form_widget(form.birthdate.year, {label: false, attr: {
                                class: 'w-full',
                                placeholder: 'Année',
                                validate: "['required']",
                                onCheck: "setFieldValid('birthYear')",
                                searchBoxProps: {'x-numberonly': ''},
                            }}) }}
                        </fieldset>

                        {{ form_errors(form.birthdate) }}
                    </fieldset>

                    {% if form.birthPlace is defined %}
                        {{ form_row(form.birthPlace, {
                            label: event.labelBirthPlace|default('Lieu de naissance'),
                            attr: {placeholder: 'Ma ville de naissance', onCheck: "setFieldValid('birthPlace')", validate: "['required']"},
                        }) }}
                    {% endif %}

                    <fieldset class="mb-4">
                        {{ form_row(form.phone, {label: 'Numéro de téléphone (optionnel)', help: 'En nous communiquant votre téléphone, vous recevrez votre billet par SMS.'}) }}
                    </fieldset>

                    {% if form.emergencyContactName is defined %}
                        <div class="flex flex-col bg-ui_gray-1 rounded-lg gap-4 p-6">
                            <label class="font-bold" for="{{ form.emergencyContactName.vars.id }}">{{ event.labelEmergencyContact|default("Contact en cas d'urgence" ~ (event.requiredEmergencyContact ? ' (obligatoire)' : '')) }}</label>

                            <div class="text-ui_gray-50">En cas de problème nous contacterons cette personne.</div>

                            {{ form_row(form.emergencyContactName) }}

                            <fieldset>
                                {{ form_row(form.emergencyContactPhone) }}
                            </fieldset>
                        </div>
                    {% endif %}

                    {% if form.isJAM is defined %}
                        <div class="bg-ui_gray-1 rounded-lg p-6">
                            {{ form_row(form.isJAM, {label: event.labelIsJAM|default('Je suis membre des Jeunes en marche'), attr: {widget_side: 'right'}}) }}
                        </div>
                    {% endif %}

                    {% if form.transportNeeds is defined or form.volunteer is defined or form.withChildren is defined or form.accessibility is defined %}
                        <div class="bg-ui_gray-1 rounded-lg p-6 flex flex-col gap-4">
                            {% if form.transportNeeds is defined %}
                                {{ form_row(form.transportNeeds, {label: event.labelTransportNeeds|default("J'ai besoin d'un transport organisé"), attr: {widget_side: 'right'}}) }}
                            {% endif %}

                            {% if form.volunteer is defined %}
                                {{ form_row(form.volunteer, {label: event.labelVolunteer|default("Je souhaite être bénévole pour aider à l'organisation"), attr: {widget_side: 'right'}}) }}
                            {% endif %}

                            {% if form.withChildren is defined %}
                                <div x-data="{with_children: {{ form.withChildren.vars.data == true ? 'true' : 'false' }}}">
                                    {{ form_row(form.withChildren, {label: event.labelWithChildren|default('Je viens avec mes enfants'), attr: {widget_side: 'right', 'x-model': 'with_children'}}) }}

                                    <fieldset class="bg-gray-100 mt-2 flex flex-col gap-4 rounded-lg p-4" x-show="with_children" x-transition>
                                        <span class="text-sm font-medium text-gray-900">Veuillez indiquer le nom, prénom et âge de chaque enfant.</span>

                                        {{ form_row(form.children, {label: false}) }}

                                        {{ form_row(form.isResponsibilityWaived, {label: 'Déclare, en qualité de responsable légal, décharger de toute responsabilité le Parti Renaissance concernant les blessures et dommages matériels ou corporels occasionnés ou subis par mon enfant, en cas de vol ou de perte de biens ainsi que toute dégradation des sites pouvant lui être imputées.', attr: {widget_side: 'right'}}) }}
                                    </fieldset>
                                </div>
                            {% endif %}

                            {% if form.accessibility is defined %}
                                <div>
                                    <twig:Molecules:ReCheckboxField widgetSide="right" id="accessibility-checkbox" x-model="accessibility">
                                        <label for="accessibility-checkbox">{{ event.labelAccessibility|default("J'ai un handicap visible ou invisible nécessitant des aménagements spécifiques") }}</label>
                                    </twig:Molecules:ReCheckboxField>
                                </div>
                                <div x-show="accessibility" x-transition>
                                    {{ form_row(form.accessibility, {label: false, attr: {rows: 6, placeholder: 'Décrivez les aménagements que nous pourrions anticiper'}}) }}
                                </div>
                            {% endif %}
                        </div>
                    {% endif %}

                    <twig:ReButton class="w-full" color="blue">Enregistrer les modifications</twig:ReButton>

                    {% if event.isPackageEventType() %}
                        <twig:ReButton tag="a" href="{{ path('app_national_event_my_inscription', {slug: event.slug, uuid: inscription.uuid}) }}" class="w-full" color="white">Annuler</twig:ReButton>
                    {% endif %}
                </twig:Atoms:ReCard>
            </div>

            <input type="hidden" id="email-validation-token" value="{{ email_validation_token }}"/>
        {{ form_end(form) }}
    </div>
{% endblock %}
