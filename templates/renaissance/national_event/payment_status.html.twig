{% extends 'base_renaissance.html.twig' %}

{% block page_title 'Statut du paiement' %}

{% block favicons %}
    {% if event is defined and event.faviconImage %}
        <link rel="icon" type="image/png" href="{{ vich_uploader_asset(event.faviconImage) }}" sizes="32x32" />
    {% else %}
        {{ parent() }}
    {% endif %}
{% endblock %}

{% block content %}
    <twig:ReStandaloneLayout class="bg-ui_gray-5">
        <twig:Atoms:ReCard class="max-w-[500px]">
            {% if status == 'limit' %}
                <twig:ReParagraphStatus status="warning" icon="warning" class="w-full justify-center" slim="true">
                    Un problème est survenu
                </twig:ReParagraphStatus>

                <p class="text-ui_gray-80 font-medium">Pour des raisons de sécurité, nous limitons le nombre de tentatives de paiement.
                    Pas d’inquiétude, vous pourrez réessayer dans quelques instants.</p>

                <twig:ReButton tag="a" href="{{ path('app_national_event_new_payment', {slug: event.slug, uuid: inscription.uuid}) }}" color="blue">Retourner vers la page de paiement</twig:ReButton>
            {% elseif status == 'pending' %}
                {% if payment_check_url is defined and payment_check_url %}
                    <twig:ReParagraphStatus status="info" class="w-full justify-center" slim="true">
                        Vérification en cours ...
                    </twig:ReParagraphStatus>

                    <div class="relative flex h-6 w-6 items-center justify-center self-center">
                        <div class="animate-ping absolute inline-flex h-full w-full rounded-full bg-sky-400 opacity-75"></div>
                        <div class="relative inline-flex rounded-full h-5 w-5 bg-sky-500"></div>
                    </div>

                    <p class="text-ui_gray-80 font-medium text-center">Nous attendons la validation de votre banque. Merci de ne pas fermer cette page, vous serez redirigé automatiquement.</p>

                    <twig:ReButton tag="a" href="{{ path('app_national_event_my_inscription', {slug: event.slug, uuid: inscription.uuid}) }}" color="blue" stroke>Voir mon inscription</twig:ReButton>
                {% else %}
                    <twig:ReParagraphStatus status="info" class="w-full justify-center" slim="true">
                        Paiement en cours de traitement
                    </twig:ReParagraphStatus>

                    <p class="text-ui_gray-80 font-medium">Votre paiement est en cours de validation par votre banque. Vous recevrez la confirmation de votre inscription par e-mail dès qu’il sera finalisé.</p>

                    <twig:ReButton tag="a" href="{{ path('app_national_event_my_inscription', {slug: event.slug, uuid: inscription.uuid}) }}" color="blue">Voir mon inscription</twig:ReButton>
                {% endif %}
            {% elseif status == 'cancel' %}
                <twig:ReParagraphStatus status="warning" icon="warning" class="w-full justify-center" slim="true">
                    Un problème est survenu
                </twig:ReParagraphStatus>

                <p class="text-ui_gray-80 font-medium">Le paiement a été annulé. Aucune somme ne vous a été prélevée.</p>

                <twig:ReButton tag="a" href="{{ path('app_national_event_new_payment', {slug: event.slug, uuid: inscription.uuid}) }}" color="blue">Retourner vers la page de paiement</twig:ReButton>
            {% else %}
                <twig:ReParagraphStatus status="error" icon="error" class="w-full justify-center" slim="true">
                    Un problème est survenu
                </twig:ReParagraphStatus>

                <p class="text-ui_gray-80 font-medium">Nous n'avons rien reçu ou la banque indique que le paiement n'a pas eu lieu. Votre compte bancaire n'a pas été débité.</p>

                <twig:ReButton tag="a" href="{{ path('app_national_event_new_payment', {slug: event.slug, uuid: inscription.uuid}) }}" color="blue">Retourner vers la page de paiement</twig:ReButton>
            {% endif %}

            <hr />

            <div class="text-ui_gray-80 text-center">
                {% if event.textIntroContact %}
                    {{ event.textIntroContact|bo_html }}
                {% else %}
                    <p>Une question relative à l’inscription ?<br/>Écrivez-nous à <a href="mailto:evenements@parti-renaissance.fr" class="text-ui_blue-50">evenements@parti-renaissance.fr</a> ou appelez-nous au <a href="tel:+33186950286" class="text-ui_blue-50">01 86 95 02 86</a></p>
                {% endif %}
            </div>
        </twig:Atoms:ReCard>
    </twig:ReStandaloneLayout>
{% endblock %}

{% block final_javascripts %}
    {% if payment_check_url is defined and payment_check_url %}
        <script type="text/javascript">
            Bootstrap.onLoad(async function() {
                await Main.runPaymentStatusPage('{{ payment_check_url }}');
            });
        </script>
    {% endif %}
{% endblock %}
