# .env.local.dist — valeurs à remplir en local si nécessaire
# Copier dans .env.local et adapter selon l'environnement local.

###> RE-5165 PostHog multi-marque ###
# Regex host pattern pour les nouvelles routes analytics (utilisé Task 6, 12).
# USER_VOX_HOST reste inchangé (28+ occurrences firewall/OIDC/Twig/services intactes).
USER_VOX_HOST_REGEX=utilisateur\.(parti-renaissance|attalpresident|avecgabrielattal|nouvellerepublique)\.fr

# PostHog activation (feature flag prod)
POSTHOG_ENABLED=false
POSTHOG_API_KEY=
POSTHOG_HOST=https://eu.i.posthog.com

# Salts marque-specific (aligne prod attalpresident.fr, format SHA256("SALT:email"))
HASH_EMAIL_SALT_ATTAL=attalpresident-2027
HASH_EMAIL_SALT_PR=parti-renaissance-2027
HASH_EMAIL_SALT_AGA=avecgabrielattal-2027
HASH_EMAIL_SALT_NR=nouvellerepublique-2027

# Release tracking (super-properties deploy_sha, deploy_version)
DEPLOY_SHA=
APP_VERSION=
###< RE-5165 PostHog multi-marque ###
