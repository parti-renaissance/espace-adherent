{
	skip_install_trust

	{$CADDY_GLOBAL_OPTIONS}

	servers {
		trusted_proxies static {$TRUSTED_PROXIES_WITH_SPACE:}
	}

	frankenphp {
		{$FRANKENPHP_CONFIG}
	}

	# Debug
	{$CADDY_DEBUG}
	auto_https off
}

{$CADDY_EXTRA_CONFIG}

:80 {
	@health_checks {
		path /healthcheck /ping
	}

	@static {
		path *.css *.js *.map *.png *.jpg *.jpeg *.gif *.svg *.webp *.avif *.woff *.woff2 *.ttf *.otf *.eot *.ico
	}

	@maintenance {
		not path /healthcheck /ping
		expression {env.ENABLE_MAINTENANCE} == "1"
	}
	rewrite @maintenance /maintenance.html

	log_skip @health_checks
	log_skip @static

	log {
		output stderr
		level {$CADDY_LOG_LEVEL:INFO}
		format filter {
			wrap json {
				time_format iso8601
			}
			fields {
				level rename severity
				msg rename message
				request.headers delete
				resp_headers delete
				request.cookies delete
			}
		}
	}

	# Pick APP_ENV per request: 'test' on test.*.code hostnames, container env otherwise.
	@testHost host test.*.code
	vars @testHost app_env test
	vars app_env {env.APP_ENV}

	root /srv/app/public
	encode zstd br gzip

	route {
		@ping path /ping
		respond @ping "pong" 200

		# Security headers
		header ?Permissions-Policy "interest-cohort=()"
		header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		header Referrer-Policy "strict-origin-when-cross-origin"
		header Cross-Origin-Opener-Policy "same-origin"

		@noLiveEvent not path /live-event/*
		header @noLiveEvent Content-Security-Policy "frame-ancestors 'self' https://*.parti-renaissance.fr"
		header X-Content-Type-Options "nosniff"

		# Block direct access to any .php (only the front controller is allowed)
		@blockedPhp {
			path *.php
			not path /index.php
		}
		respond @blockedPhp 404

		@mercure path /.well-known/mercure*
		reverse_proxy @mercure {$MERCURE_HOST:mercure}:80 {
			header_up Host {host}

			# SSE: disable read and write buffers
			transport http {
				read_buffer 0
				write_buffer 0
			}
		}

		# Cached built assets : 404 if not found
		# The immutable header is only set on hits: a 404 must stay cheap to
		# revalidate, otherwise a CDN freezes it for a year (see @builtAssetsFound).
		@builtAssets path /built/*
		@builtAssetsFound {
			path /built/*
			file
		}
		header @builtAssetsFound Cache-Control "public, max-age=31536000, immutable"
		file_server @builtAssets

		@phpRoute {
			not file
		}
		rewrite @phpRoute index.php

		@frontController path index.php
		php @frontController {
			env APP_ENV {vars.app_env}
			resolve_root_symlink false
		}

		file_server
	}
}
