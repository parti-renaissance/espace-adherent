{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Settings de base socle (templates/settings/repo-baseline.json) + enrichissement local : ce projet utilise 'master' comme branche principale.",
  "enabledPlugins": {
    "superpowers@superpowers-dev": true
  },
  "extraKnownMarketplaces": {
    "superpowers-dev": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers"
      }
    }
  },
  "permissions": {
    "deny": [
      "Bash(rm -rf /:*)",
      "Bash(rm -rf ~/:*)",
      "Bash(rm -rf $HOME:*)",
      "Bash(rm -rf ~:*)",
      "Bash(rm -f /:*)",
      "Bash(sudo:*)",
      "Bash(curl * | sh:*)",
      "Bash(curl * | bash:*)",
      "Bash(wget * | sh:*)",
      "Bash(wget * | bash:*)",
      "Bash(gcloud * delete:*)",
      "Bash(gcloud sql databases delete:*)",
      "Bash(gcloud sql instances delete:*)",
      "Bash(gcloud projects delete:*)",
      "Bash(gh repo delete:*)",
      "Bash(gh secret delete:*)",
      "Bash(docker rm -f:*)",
      "Bash(docker rmi -f:*)",
      "Bash(docker system prune -a:*)",
      "Bash(kubectl delete:*)",
      "Bash(git push origin main --force:*)",
      "Bash(git push --force origin main:*)",
      "Bash(git push -f origin main:*)",
      "Bash(git push origin main --force-with-lease:*)",
      "Bash(git push --force-with-lease origin main:*)",
      "Bash(git reset --hard origin/main:*)",
      "Bash(git branch -D main:*)",
      "Bash(git push origin master --force:*)",
      "Bash(git push --force origin master:*)",
      "Bash(git push -f origin master:*)",
      "Bash(git push origin master --force-with-lease:*)",
      "Bash(git push --force-with-lease origin master:*)",
      "Bash(git reset --hard origin/master:*)",
      "Bash(git branch -D master:*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git reset --hard:*)",
      "Bash(git rebase:*)",
      "Bash(gh release create:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh secret set:*)",
      "Bash(npm publish:*)",
      "Bash(npm unpublish:*)",
      "Bash(pnpm publish:*)",
      "Bash(gcloud run deploy:*)",
      "Bash(gcloud sql:*)",
      "Bash(docker push:*)"
    ]
  }
}
